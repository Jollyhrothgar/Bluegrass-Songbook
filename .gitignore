# --- Python ---
# Bytecode and cache files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
wheels/
*.tar.gz

# --- Virtual Environments ---
# (Poetry usually manages globally, but good practice to include standard names)
.venv/
venv/
ENV/
env/
*/.venv/
*/venv/
*/ENV/
*/env/

# --- Poetry ---
# (Poetry cache is usually global ~/.cache/pypoetry, but ignore local just in case)
.poetry/

# --- IDEs / Editors ---
# VS Code
.vscode/
# PyCharm
.idea/

# --- Operating System ---
# macOS
.DS_Store
# Windows
Thumbs.db

# --- Testing ---
.pytest_cache/
.coverage* # Coverage reports
htmlcov/   # HTML coverage report

# --- Project Specific Artifacts ---
# Log files generated by the script
*.log

# JSON output file generated by the script
*.json

# --- Data Sources ---
# Ignore the sources directory containing potentially large amounts of scraped HTML
# IMPORTANT: Assumes you don't want to track this data in Git.
# If you *do* want to track it, consider Git LFS, but generally large datasets
# like this are kept outside the code repository.
sources/

# --- Other ---
# Add any other specific files or directories you want Git to ignore
# e.g., temporary files, specific config files with secrets (.env)