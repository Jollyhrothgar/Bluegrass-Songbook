# Secrets for Bluegrass Songbook CLI / maintenance scripts
# (Strum Machine matching, LLM tagging, Supabase sync).
#
# Preferred: run ./scripts/bootstrap — it auto-generates .env from 1Password
# (see .env.tpl). Manual fallback: copy this file to .env and fill in values.
# The analytics dashboard uses a separate analytics/.env.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
# Same value as SUPABASE_SERVICE_KEY; some CI/maintenance scripts read this name.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
STRUM_MACHINE_API_KEY=your-strum-machine-key-here
ANTHROPIC_API_KEY=sk-ant-...
